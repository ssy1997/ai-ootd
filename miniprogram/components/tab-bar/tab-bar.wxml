<!-- Tab Bar 组件 -->
<view class="tab-bar">
  <view 
    class="tab-bar__item {{activeTab === 'closet' ? 'tab-bar__item--active' : ''}}" 
    bindtap="handleTabClick" 
    data-tab="closet"
  >
    <image class="tab-bar__icon" src="/images/icon-closet.svg" mode="aspectFit" />
    <text class="tab-bar__label">衣橱</text>
  </view>

  <view 
    class="tab-bar__item {{activeTab === 'recommend' ? 'tab-bar__item--active' : ''}}" 
    bindtap="handleTabClick" 
    data-tab="recommend"
  >
    <view class="tab-bar__icon-wrapper">
      <image class="tab-bar__icon tab-bar__icon--large" src="/images/icon-recommend.svg" mode="aspectFit" />
    </view>
    <text class="tab-bar__label">推荐</text>
  </view>

  <view 
    class="tab-bar__item {{activeTab === 'profile' ? 'tab-bar__item--active' : ''}}" 
    bindtap="handleTabClick" 
    data-tab="profile"
  >
    <image class="tab-bar__icon" src="/images/icon-profile.svg" mode="aspectFit" />
    <text class="tab-bar__label">我的</text>
  </view>
</view>
